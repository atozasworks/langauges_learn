{
  "name": "atozas-react-auth-kit",
  "version": "1.0.1",
  "description": "Production-ready React authentication components for Google OAuth and Email OTP",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "npx tsup",
    "dev": "npx tsup --watch",
    "clean": "npx rimraf dist"
  },
  "keywords": [
    "react",
    "auth",
    "google-oauth",
    "otp",
    "authentication"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@react-oauth/google": "^0.12.1",
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
