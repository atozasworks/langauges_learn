# =============================================
# LAN Learn — Environment Variables Template
# =============================================
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
# NEVER commit the .env file itself.
# =============================================

# ── Node Server ──
PORT=3000
NODE_ENV=development
OTP_LENGTH=6
OTP_TTL_SECONDS=300

# ── Auth Kit (Google + JWT) ──
# Required in production
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
# Optional comma-separated list for cross-origin frontend(s)
FRONTEND_URL=
# Optional token expiry overrides
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d
# Optional OTP throttling
OTP_RATE_LIMIT_ATTEMPTS=3
OTP_RATE_LIMIT_WINDOW_MS=900000

# ── MongoDB Compass ──
# Example URI for local Compass default server
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=lldb

# ── SMTP Mail ──
# Optional for OTP email sending; if omitted in dev, OTP is logged in server console.
SMTP_NAME=example.com
SMTP_SERVER=mail.example.com
# SMTP_HOST can be used instead of SMTP_SERVER
# SMTP_USER can be used instead of SMTP_EMAIL
# SMTP_PASS / SMTP_APP_PASSWORD can be used instead of SMTP_PASSWORD
# Optional: SMTP_SERVICE=gmail (or other known nodemailer service)
SMTP_PORT=465
SMTP_SECURE=true
SMTP_EMAIL=no-reply@example.com
SMTP_PASSWORD=your-smtp-password
# Optional explicit from address (defaults to SMTP_EMAIL)
SMTP_FROM=no-reply@example.com
SMTP_REQUIRE_TLS=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_CONNECTION_TIMEOUT=15000
SMTP_GREETING_TIMEOUT=10000
SMTP_SOCKET_TIMEOUT=20000
