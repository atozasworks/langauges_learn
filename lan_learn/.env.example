# =============================================
# LAN Learn — Environment Variables Template
# =============================================
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
# NEVER commit the .env file itself.
# =============================================

# ── Google OAuth 2.0 ──
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth-backend/google-callback.php

# ── Database ──
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lan_learn_auth
DB_USERNAME=root
DB_PASSWORD=

# ── Groq AI ──
GROQ_API_KEY=your-groq-api-key

# ── SMTP Mail ──
SMTP_NAME=example.com
SMTP_SERVER=mail.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_EMAIL=no-reply@example.com
SMTP_PASSWORD=your-smtp-password
